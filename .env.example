# Database Settings
DB_HOST=localhost
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=your_db_name

# Application Settings
APP_NAME="StoreOps"
APP_INITIALS="SO"
COMPANY_NAME="Richmond Tech Group"

# Header clock timezones (optional)
TIMEZONE_US="America/New_York"
TIMEZONE_LOCAL="Asia/Karachi"
TIMEZONE_US_LABEL="US"
TIMEZONE_LOCAL_LABEL="PK"

# production | development
APP_ENV=production
APP_DEBUG=false

# Optional Base URL Override (recommended on live server)
# BASE_URL=https://yourdomain.com
